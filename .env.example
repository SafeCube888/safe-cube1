# ============================================================
# SAFE CUBE — Environment Variables
# ============================================================
# Copy this file to .env and fill in the real values.
# Never commit the .env file. Never expose secret keys in
# client-side code (only NEXT_PUBLIC_* vars are exposed).
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://safecube.example

# --- Supabase (public, client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (server-only, never expose to client) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (transactional email, used in Edge Functions) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Cloudflare Turnstile (spam protection) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Admin notifications ---
ADMIN_NOTIFICATION_EMAIL=
